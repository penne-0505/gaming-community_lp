{
  "name": "clover_web_page",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "husky install",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.functions.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check \"src/**/*.{ts,tsx,css}\" \"functions/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.{js,ts}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"functions/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.{js,ts}\"",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@sentry/browser": "^10.32.1",
    "@sentry/cloudflare": "^10.32.1",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^11.5.2",
    "lucide-react": "^0.556.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.2",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@eslint/js": "^9.39.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.15.21",
    "@types/react": "~18.3.18",
    "@types/react-dom": "~18.3.5",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "**/*.css": [
      "prettier --write"
    ]
  }
}
