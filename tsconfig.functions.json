{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "allowJs": false,
    "noFallthroughCasesInSwitch": true,
    "types": ["@cloudflare/workers-types", "node"]
  },
  "include": ["functions", "tests"]
}
